; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MOONLITE"
config/version="0.0.6"
run/main_scene="uid://d3yy05k4icstv"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/image="uid://b5xf8qnqb02tm"
config/icon="uid://ckx2s73jm5621"
config/windows_native_icon="res://art/icons/icon.ico"

[audio]

buses/default_bus_layout="uid://bk1gmfmvp6ejl"

[autoload]

AudioEngine="*uid://crunyoff7twqb"
MusicEngine="*uid://dv6is2lkh8fq"
Stats="*uid://c4v0n4768dg15"
Volume="*uid://c73r6mshopcn2"
SaveIcon="*uid://datb8fgwhqjj4"
Dash="*uid://dgf5c08bcodv3"
Dialogic="*uid://ds2q0uclmolvu"
DebugDisplay="*uid://dtt4andy8x6y7"
Camera="*uid://cy74lofx67fxd"
Slide="*uid://bkwmstlw8s8de"

[dialogic]

directories/dch_directory={
"dummy": "res://assets/data/dialogue/characters/dummy.dch",
"moonlite": "res://assets/data/dialogue/characters/moonlite.dch"
}
directories/dtl_directory={
"dummyDialogueTutorial": "res://assets/data/dialogue/dummyDialogueTutorial.dtl",
"test": "res://assets/data/dialogue/test.dtl"
}
layout/style_directory={
"": "res://assets/data/dialogue/styles/default.tres",
"default": "res://assets/data/dialogue/styles/default.tres"
}
variables={
"isDone": false
}
layout/style_list=["res://assets/data/dialogue/styles/default.tres"]
layout/default_style="res://assets/data/dialogue/styles/default.tres"
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.2
animations/join_default_wait=false
animations/leave_default_length=0.2
animations/leave_default_wait=false
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
animations/join_default="Instant In"
animations/leave_default="Instant Out"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/vsync/vsync_mode=0
mouse_cursor/custom_image="uid://cnhatn46jymk"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/godot_sparrow/plugin.cfg")

[importer_defaults]

com.what-is-a-git.godot-sparrow-importer={
"animation_framerate": 24,
"animations_looped": true,
"store_external_spriteframes": false,
"use_offsets": true
}

